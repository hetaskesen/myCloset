# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=your_random_secret_here

# From Railway PostgreSQL dashboard
DATABASE_URL=postgresql://user:password@host:port/dbname

# From Cloudinary dashboard (free account at cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Generate VAPID keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:you@example.com

PORT=3001
