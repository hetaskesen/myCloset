# Copy this to .env and fill in your values
# NEVER commit .env to git

NODE_ENV=development
PORT=3001

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=your_random_secret_here

# Local PostgreSQL (for local dev)
# Format: postgresql://USER:PASSWORD@localhost:5432/mycloset
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mycloset

# Cloudinary — sign up free at cloudinary.com
# Leave blank to skip photo uploads during local dev
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# VAPID keys for push notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com
